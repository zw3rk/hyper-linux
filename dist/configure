#!/bin/sh
# configure — write config.mk with install prefix
#
# Copyright 2025 Moritz Angermann <moritz@zw3rk.com>, zw3rk pte. ltd.
# SPDX-License-Identifier: Apache-2.0

PREFIX=/usr/local

for arg in "$@"; do
    case "$arg" in
        --prefix=*)
            PREFIX="${arg#--prefix=}"
            ;;
        --help|-h)
            echo "Usage: ./configure [--prefix=DIR]"
            echo ""
            echo "  --prefix=DIR    Installation prefix [/usr/local]"
            echo ""
            echo "Creates config.mk with PREFIX, BINDIR, and MANDIR."
            exit 0
            ;;
        *)
            echo "configure: unknown option: $arg" >&2
            echo "Try './configure --help' for usage." >&2
            exit 1
            ;;
    esac
done

cat > config.mk <<EOF
PREFIX  = ${PREFIX}
BINDIR  = \$(PREFIX)/bin
MANDIR  = \$(PREFIX)/share/man
EOF

echo "Configured with PREFIX=${PREFIX}"
echo "Written config.mk"
